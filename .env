AJENDA_APP_NAME=Ajenda AI
AJENDA_ENV=production
AJENDA_LOG_LEVEL=INFO
AJENDA_LOG_JSON=true
AJENDA_HOST=0.0.0.0
AJENDA_PORT=8000
AJENDA_DATABASE_URL=postgresql+psycopg://ajenda:${POSTGRES_PASSWORD}@db:5432/ajenda
AJENDA_DB_POOL_SIZE=20
AJENDA_DB_MAX_OVERFLOW=40
AJENDA_DB_POOL_TIMEOUT=30
AJENDA_DB_POOL_RECYCLE=1800
AJENDA_REDACT_KEYS=password,secret,token,api_key,authorization,cookie,set-cookie
AJENDA_QUEUE_ADAPTER=redis
AJENDA_QUEUE_URL=redis://redis:6379/0
AJENDA_RATE_LIMIT_REQUESTS=200
AJENDA_RATE_LIMIT_WINDOW_SECONDS=60
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_ENABLED=true
