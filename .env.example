# Omnipath v2.0 Environment Configuration
# Copy this file to .env and update with your values
# IMPORTANT: Never commit .env to git (it's in .gitignore)

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=Omnipath
APP_VERSION=2.0.0
DEBUG=True
ENVIRONMENT=development

# ============================================================================
# SECURITY (REQUIRED)
# ============================================================================
# Generate random secrets using: openssl rand -hex 32
# NEVER use the placeholder values below in any deployed environment.
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# DATABASE (Optional for testing - defaults to SQLite)
# ============================================================================
# Development: SQLite (automatic fallback when DATABASE_URL is not set)
# Production: postgresql://USER:STRONG_PASSWORD@HOST:5432/DBNAME
DATABASE_URL=sqlite:///./omnipath_dev.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================================================
# REDIS (Optional - can be disabled for testing)
# ============================================================================
# Production: redis://:STRONG_PASSWORD@HOST:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ============================================================================
# NATS EVENT BUS (Optional - can be disabled for testing)
# ============================================================================
# Production: nats://USER:STRONG_PASSWORD@HOST:4222
NATS_URL=nats://localhost:4222
NATS_MAX_RECONNECT_ATTEMPTS=10
NATS_ENABLE_JETSTREAM=True

# ============================================================================
# OPENTELEMETRY (Optional - disable for testing)
# ============================================================================
OTEL_ENABLED=False
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_INSECURE=True

# ============================================================================
# LANGFUSE (Optional - LLM Observability)
# ============================================================================
# Get keys from: https://cloud.langfuse.com
LANGFUSE_ENABLED=False
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================================
# RATE LIMITING (Optional - disable for testing)
# ============================================================================
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# AGENT SYSTEM
# ============================================================================
MAX_AGENTS_PER_TENANT=100
AGENT_EXECUTION_TIMEOUT_SECONDS=300
AGENT_MEMORY_LIMIT_MB=512
ENABLE_EVENT_SOURCING=True

# ============================================================================
# SAGA ORCHESTRATION
# ============================================================================
SAGA_DEFAULT_TIMEOUT_SECONDS=60
SAGA_MAX_RETRIES=3

# ============================================================================
# AUDIT & LOGGING
# ============================================================================
AUDIT_LOG_ENABLED=True
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=True

# ============================================================================
# MONITORING (Optional - disable for testing)
# ============================================================================
PROMETHEUS_ENABLED=False
PROMETHEUS_PORT=9090

# ============================================================================
# LLM PROVIDERS - API KEYS (REQUIRED)
# ============================================================================

# OpenAI (REQUIRED - Primary provider for specialized agents)
# Get key from: https://platform.openai.com/api-keys
# Used by: ResearcherAgent, AnalystAgent, DeveloperAgent, Commander
OPENAI_API_KEY=

# Anthropic (Optional - for Claude models)
# Get key from: https://console.anthropic.com/settings/keys
# Used by: Guardian Agent (safety validation)
# NOTE: Requires active billing/credits
ANTHROPIC_API_KEY=

# Google (Optional - for Gemini models)
# Get key from: https://makersuite.google.com/app/apikey
# Used by: Archivist Agent, Fork Agents
# NOTE: May require Gemini API to be enabled in Google Cloud
GOOGLE_API_KEY=

# xAI (Optional - for Grok models)
# Get key from: https://console.x.ai/
XAI_API_KEY=

# Ollama (Optional - for local models, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# MODEL SELECTION (Multi-Model Strategy)
# ============================================================================

# Commander Agent (Decision-making, complex reasoning)
COMMANDER_PROVIDER=openai
COMMANDER_MODEL=gpt-4-turbo
COMMANDER_TEMPERATURE=0.7

# Guardian Agent (Safety validation, rule enforcement)
# NOTE: Requires Anthropic API key with credits
GUARDIAN_PROVIDER=anthropic
GUARDIAN_MODEL=claude-3-5-sonnet-20241022
GUARDIAN_TEMPERATURE=0.3

# Archivist Agent (Memory management, logging)
# NOTE: Requires Google API key with Gemini enabled
ARCHIVIST_PROVIDER=google
ARCHIVIST_MODEL=gemini-2.0-flash-exp
ARCHIVIST_TEMPERATURE=0.5

# Fork Agents (Worker agents, routine tasks)
FORK_PROVIDER=google
FORK_MODEL=gemini-2.0-flash-exp
FORK_TEMPERATURE=0.7

# Specialized Agents (Research, Analysis, Development)
# These use OpenAI by default (requires OPENAI_API_KEY)
RESEARCHER_PROVIDER=openai
RESEARCHER_MODEL=gpt-4-turbo
RESEARCHER_TEMPERATURE=0.7

ANALYST_PROVIDER=openai
ANALYST_MODEL=gpt-4-turbo
ANALYST_TEMPERATURE=0.5

DEVELOPER_PROVIDER=openai
DEVELOPER_MODEL=gpt-4-turbo
DEVELOPER_TEMPERATURE=0.3

# ============================================================================
# MODEL CONTEXT PROTOCOL (Optional)
# ============================================================================
MCP_ENABLED=False
MCP_SERVER_URL=http://localhost:8001

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Generate security secrets:
#    python3 -c "import secrets; print('SECRET_KEY=' + secrets.token_urlsafe(32))"
#    python3 -c "import secrets; print('JWT_SECRET_KEY=' + secrets.token_urlsafe(32))"
# 3. Add your OpenAI API key (REQUIRED)
# 4. (Optional) Add other LLM provider keys
# 5. (Optional) Configure Langfuse for LLM observability
# 6. Save the file
# 7. Run: pytest tests/integration/test_specialized_agents.py -v

# ============================================================================
# MINIMAL SETUP (For Quick Testing)
# ============================================================================
# Only these are required for basic functionality:
# - SECRET_KEY (any random string)
# - JWT_SECRET_KEY (any random string)
# - OPENAI_API_KEY (get from OpenAI)
#
# Everything else can use defaults or be disabled.
