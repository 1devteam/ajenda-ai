# =============================================================================
# Ajenda AI — Development Environment Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Adjust values for your local setup
#   3. NEVER commit .env to version control
# =============================================================================

# --- Database ---
# Development default — change for your local Postgres instance
AJENDA_DATABASE_URL=postgresql+psycopg://ajenda:ajenda@localhost:5432/ajenda
AJENDA_DB_POOL_SIZE=5
AJENDA_DB_MAX_OVERFLOW=10
AJENDA_DB_POOL_TIMEOUT=30
AJENDA_DB_POOL_RECYCLE=1800

# --- Application ---
AJENDA_APP_NAME=Ajenda AI
AJENDA_ENV=development
AJENDA_LOG_LEVEL=DEBUG
AJENDA_LOG_JSON=false
AJENDA_HOST=0.0.0.0
AJENDA_PORT=8000

# --- Security ---
AJENDA_REDACT_KEYS=password,secret,token,api_key,authorization,cookie,set-cookie

# --- OIDC / JWT (optional in development — leave blank to disable JWT auth) ---
AJENDA_OIDC_ISSUER=
AJENDA_OIDC_AUDIENCE=ajenda-api

# --- Queue ---
AJENDA_QUEUE_ADAPTER=redis
AJENDA_QUEUE_URL=redis://localhost:6379/0

# --- Rate Limiting ---
AJENDA_RATE_LIMIT_REQUESTS=1000
AJENDA_RATE_LIMIT_WINDOW_SECONDS=60
