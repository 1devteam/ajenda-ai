# =============================================================================
# Ajenda AI — Production Environment Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.prod.example .env.prod
#   2. Fill in every value marked REQUIRED
#   3. NEVER commit .env.prod to version control
#   4. Use a secrets manager (AWS Secrets Manager, Vault, K8s Secrets) in prod
# =============================================================================

# --- Database ---
# REQUIRED: Set a strong random password (min 32 chars)
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_RANDOM_PASSWORD

# DATABASE_URL references POSTGRES_PASSWORD via shell variable expansion.
# Docker Compose expands ${POSTGRES_PASSWORD} at runtime. Never hardcode it.
AJENDA_DATABASE_URL=postgresql+psycopg://ajenda:${POSTGRES_PASSWORD}@db:5432/ajenda
AJENDA_DB_POOL_SIZE=20
AJENDA_DB_MAX_OVERFLOW=40
AJENDA_DB_POOL_TIMEOUT=30
AJENDA_DB_POOL_RECYCLE=1800

# --- Application ---
AJENDA_APP_NAME=Ajenda AI
AJENDA_ENV=production
AJENDA_LOG_LEVEL=INFO
AJENDA_LOG_JSON=true
AJENDA_HOST=0.0.0.0
AJENDA_PORT=8000

# --- Security ---
# Fields to redact from all structured logs (comma-separated)
AJENDA_REDACT_KEYS=password,secret,token,api_key,authorization,cookie,set-cookie

# --- OIDC / JWT (REQUIRED for JWT-authenticated requests) ---
# Your OIDC provider issuer URL (e.g. https://accounts.google.com or Keycloak URL)
AJENDA_OIDC_ISSUER=https://your-oidc-provider.example.com
# The audience claim your provider sets in issued JWTs
AJENDA_OIDC_AUDIENCE=ajenda-api

# --- Queue ---
AJENDA_QUEUE_ADAPTER=redis
# If Redis requires auth: redis://:PASSWORD@host:port/db
# If Redis has no auth:   redis://host:port/db
AJENDA_QUEUE_URL=redis://redis:6379/0

# --- Rate Limiting ---
AJENDA_RATE_LIMIT_REQUESTS=200
AJENDA_RATE_LIMIT_WINDOW_SECONDS=60

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_ENABLED=true
