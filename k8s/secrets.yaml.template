---
# ============================================================
# Omnipath v2 — Kubernetes Secrets Template
#
# USAGE:
#   1. Copy this file: cp secrets.yaml.template secrets.yaml
#   2. Replace all <REPLACE_...> placeholders with real values
#   3. Apply: kubectl apply -f secrets.yaml
#   4. NEVER commit secrets.yaml to git (it is in .gitignore)
#
# Generate strong secrets with:
#   openssl rand -hex 32
#
# Built with Pride for Obex Blackvault
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: omnipath-secrets
  namespace: omnipath
  labels:
    app: omnipath
type: Opaque
stringData:
  # ── Application secrets ──────────────────────────────────
  secret-key:         "<REPLACE_WITH_openssl_rand_hex_32>"
  jwt-secret:         "<REPLACE_WITH_openssl_rand_hex_32>"

  # ── Database ─────────────────────────────────────────────
  # Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME
  database-url:       "<REPLACE_WITH_postgresql_connection_string>"

  # ── Redis ────────────────────────────────────────────────
  # Format: redis://:PASSWORD@HOST:6379/0
  redis-url:          "<REPLACE_WITH_redis_connection_string>"

  # ── NATS ─────────────────────────────────────────────────
  # Format: nats://USER:PASSWORD@HOST:4222
  nats-url:           "<REPLACE_WITH_nats_connection_string>"

  # ── LLM API keys ─────────────────────────────────────────
  openai-api-key:     "<REPLACE_WITH_sk_proj_...>"
  anthropic-api-key:  "<REPLACE_WITH_sk_ant_...>"
  google-api-key:     "<REPLACE_WITH_google_api_key>"
  xai-api-key:        "<REPLACE_WITH_xai_api_key>"
