{
  "title": "Omnipath System Overview",
  "tags": [
    "omnipath",
    "system"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Total Missions",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(omnipath_missions_total)",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Active Missions",
      "type": "stat",
      "targets": [
        {
          "expr": "omnipath_active_missions",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 50,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Success Rate",
      "type": "gauge",
      "targets": [
        {
          "expr": "sum(rate(omnipath_missions_total{status=\"success\"}[5m])) / sum(rate(omnipath_missions_total[5m])) * 100",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "HTTP Requests/sec",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(omnipath_http_requests_total[1m])",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2
        }
      }
    },
    {
      "id": 5,
      "title": "Mission Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(omnipath_mission_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(omnipath_mission_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Missions by Complexity",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(omnipath_missions_total{complexity=\"simple\"}[5m])",
          "legendFormat": "Simple",
          "refId": "A"
        },
        {
          "expr": "rate(omnipath_missions_total{complexity=\"moderate\"}[5m])",
          "legendFormat": "Moderate",
          "refId": "B"
        },
        {
          "expr": "rate(omnipath_missions_total{complexity=\"complex\"}[5m])",
          "legendFormat": "Complex",
          "refId": "C"
        },
        {
          "expr": "rate(omnipath_missions_total{complexity=\"swarm\"}[5m])",
          "legendFormat": "Swarm",
          "refId": "D"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Agent Invocations by Model",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (model) (omnipath_agent_invocations_total)",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "id": 8,
      "title": "HTTP Response Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(omnipath_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(omnipath_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, rate(omnipath_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "C"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(omnipath_agent_errors_total[5m])",
          "legendFormat": "Agent Errors",
          "refId": "A"
        },
        {
          "expr": "rate(omnipath_http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "HTTP 5xx",
          "refId": "B"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    }
  ],
  "id": null,
  "uid": "system_overview"
}