{
  "dashboard": {
    "title": "LLM Performance",
    "tags": ["omnipath", "llm"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Total LLM API Calls",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(omnipath_llm_api_calls_total)",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        }
      },
      {
        "id": 2,
        "title": "Total Tokens Used",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(omnipath_llm_tokens_used_total)",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "title": "Total LLM Cost",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(omnipath_llm_cost_total)",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 4
          }
        }
      },
      {
        "id": 4,
        "title": "Avg LLM Latency",
        "type": "stat",
        "targets": [
          {
            "expr": "avg(omnipath_llm_latency_seconds)",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 2
          }
        }
      },
      {
        "id": 5,
        "title": "LLM API Calls by Model",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(omnipath_llm_api_calls_total[5m])",
            "legendFormat": "{{model}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Token Usage by Model",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(omnipath_llm_tokens_used_total[5m])",
            "legendFormat": "{{model}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "fieldConfig": {
          "defaults": {
            "unit": "tps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 7,
        "title": "LLM Cost by Model",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum by (model) (omnipath_llm_cost_total)",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 8,
        "title": "LLM Latency by Model",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(omnipath_llm_latency_seconds_bucket[5m]))",
            "legendFormat": "{{model}} p95",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth"
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Cost per Token by Model",
        "type": "bargauge",
        "targets": [
          {
            "expr": "sum by (model) (omnipath_llm_cost_total) / sum by (model) (omnipath_llm_tokens_used_total)",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 6,
            "color": {"mode": "continuous-GrYlRd"}
          }
        }
      }
    ]
  }
}
