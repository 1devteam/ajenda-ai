# Omnipath v3.0 Environment Configuration
# Copy this file to .env and update with your values

# Application
APP_NAME=Omnipath
APP_VERSION=3.0.0
DEBUG=False
ENVIRONMENT=development

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://omnipath:omnipath@localhost:5432/omnipath
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis (Caching & Streams)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# NATS (Event Bus)
NATS_URL=nats://localhost:4222
NATS_MAX_RECONNECT_ATTEMPTS=10
NATS_ENABLE_JETSTREAM=True

# OpenTelemetry (Distributed Tracing)
OTEL_ENABLED=True
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_INSECURE=True

# Langfuse (LLM Observability)
LANGFUSE_ENABLED=True
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Agent System
MAX_AGENTS_PER_TENANT=100
AGENT_EXECUTION_TIMEOUT_SECONDS=300
AGENT_MEMORY_LIMIT_MB=512
ENABLE_EVENT_SOURCING=True

# Saga Orchestration
SAGA_DEFAULT_TIMEOUT_SECONDS=60
SAGA_MAX_RETRIES=3

# Audit & Logging
AUDIT_LOG_ENABLED=True
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=True

# Monitoring
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# ============================================================================
# LLM PROVIDERS - API KEYS
# ============================================================================
# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=sk-...

# Anthropic (Claude 3.5, Claude 3)
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini 2.0, Gemini 1.5)
GOOGLE_API_KEY=...

# xAI (Grok)
XAI_API_KEY=xai-...

# Ollama (Local models - no API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# MODEL SELECTION (Multi-Model Strategy)
# ============================================================================
# Commander Agent (Decision-making, complex reasoning)
COMMANDER_PROVIDER=openai
COMMANDER_MODEL=gpt-4-turbo
COMMANDER_TEMPERATURE=0.7

# Guardian Agent (Safety validation, rule enforcement)
GUARDIAN_PROVIDER=anthropic
GUARDIAN_MODEL=claude-3-5-sonnet-20241022
GUARDIAN_TEMPERATURE=0.3

# Archivist Agent (Memory management, logging)
ARCHIVIST_PROVIDER=google
ARCHIVIST_MODEL=gemini-2.0-flash-exp
ARCHIVIST_TEMPERATURE=0.5

# Fork Agents (Worker agents, routine tasks)
FORK_PROVIDER=google
FORK_MODEL=gemini-2.0-flash-exp
FORK_TEMPERATURE=0.7

# Model Context Protocol (MCP)
MCP_ENABLED=True
MCP_SERVER_URL=http://localhost:8001
